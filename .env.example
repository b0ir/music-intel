# Spotify (required for Spotify source + Discover tab)
# Get from: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret

# ISO 3166-1 alpha-2 market code for Spotify top-tracks lookup (default: US)
# See https://en.wikipedia.org/wiki/ISO_3166-1_alpha-2 for valid codes
SPOTIFY_MARKET=US

# Last.fm (optional — enables Last.fm listener/play count data)
# Get from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your_api_key

# Discogs (optional — enables vinyl market data)
# Get from: https://www.discogs.com/settings/developers
DISCOGS_USER_TOKEN=your_user_token

# AI provider key — set the one you want to use
# Supported: openai, anthropic, deepseek, openrouter, nvidia_nim, xai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
XAI_API_KEY=
